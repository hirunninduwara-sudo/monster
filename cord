orders = []

# Add Order
def add_order():
    order_id = input("Enter Order ID: ")
    customer_name = input("Enter Customer Name: ")
    food_item = input("Enter Food Item: ")
    amount = float(input("Enter Amount: "))

    order = {
        "id": order_id,
        "customer": customer_name,
        "food": food_item,
        "amount": amount,
        "status": "Pending"
    }

    orders.append(order)
    print("Order added successfully!")

# View Orders
def view_orders():
    if len(orders) == 0:
        print("No orders available.")
    else:
        print("\n--- Order List ---")
        for order in orders:
            print(f"ID: {order['id']}, Customer: {order['customer']}, "
                  f"Food: {order['food']}, Amount: {order['amount']}, "
                  f"Status: {order['status']}")

# Search Order
def search_order():
    search_id = input("Enter Order ID to search: ")

    for order in orders:
        if order["id"] == search_id:
            print("\nOrder Found:")
            print(f"ID: {order['id']}")
            print(f"Customer: {order['customer']}")
            print(f"Food: {order['food']}")
            print(f"Amount: {order['amount']}")
            print(f"Status: {order['status']}")
            return

    print("Order not found.")

# Update Order Status
def update_status():
    update_id = input("Enter Order ID to update: ")

    for order in orders:
        if order["id"] == update_id:
            order["status"] = "Completed"
            print("Order status updated to Completed.")
            return

    print("Order not found.")

# Calculate Total Sales
def total_sales():
    total = 0
    for order in orders:
        total += order["amount"]

    print("Total Sales =", total)

# Count Completed Orders
def count_completed_orders():
    count = 0

    for order in orders:
        if order["status"] == "Completed":
            count += 1

    print("Completed Orders =", count)

# Main Menu
while True:
    print("\n===== Restaurant Ordering System =====")
    print("1. Add Order")
    print("2. View Orders")
    print("3. Search Order")
    print("4. Update Order Status")
    print("5. Calculate Total Sales")
    print("6. Count Completed Orders")
    print("7. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        add_order()
    elif choice == "2":
        view_orders()
    elif choice == "3":
        search_order()
    elif choice == "4":
        update_status()
    elif choice == "5":
        total_sales()
    elif choice == "6":
        count_completed_orders()
    elif choice == "7":
        print("Thank you for using the system!")
        break
    else:
        print("Invalid choice. Please try again.")
